# =====================================================
# 🤖 MACHINE LEARNING SPECIFIC
# =====================================================

# Dados brutos (muito pesados, não commitar)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Modelos treinados e artefatos (muito pesados)
models/*.pth          # PyTorch models
models/*.pt           # PyTorch models
models/*.pkl          # Pickle files
models/*.joblib       # Joblib serialized models
models/*.h5           # Keras/TensorFlow models
models/*.onnx         # ONNX models
models/*.ckpt         # Checkpoint files
models/*.safetensors  # Hugging Face format
!models/.gitkeep      # Mantém diretório no git

# MLflow artifacts e tracking
mlruns/
**/mlruns/
.mlflow/
artifacts/
experiments.db

