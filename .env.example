# UV Configuration
# Force uv to use 'venv' directory instead of '.venv'
UV_PROJECT_ENVIRONMENT=venv

# ── MLflow ────────────────────────────────────────────────────────────────
# Local dev: aponte para o MLflow rodando localmente
MLFLOW_TRACKING_URI=http://localhost:5000/mlflow
# Produção (EC2): definida automaticamente no docker-compose pelo user_data
# MLFLOW_TRACKING_URI=https://mlflow.pocsarcotech.com/mlflow

# Experimento e run
MLFLOW_EXPERIMENT_NAME=churn-mlp
# Opcional: fixar um run_id específico em vez de usar o mais recente com recall_target_met=True
# MLFLOW_RUN_ID=

# ── API ───────────────────────────────────────────────────────────────────
API_PORT=8080
API_HOST=0.0.0.0

# ── AWS ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Bucket S3 para artefatos MLflow (deixe vazio para armazenamento local na EC2)
# MLFLOW_ARTIFACT_BUCKET=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
